{
  "name": "@nexura/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "lint": "eslint src",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nexura/database": "workspace:*",
    "@nexura/shared": "workspace:*",
    "@nexura/types": "workspace:*",
    "discord.js": "14.26.4",
    "drizzle-orm": "0.45.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}

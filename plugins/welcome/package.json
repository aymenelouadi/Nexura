{
  "name": "@nexura/plugin-welcome",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "default": "./dist/schemas/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nexura/shared": "workspace:*",
    "@nexura/types": "workspace:*",
    "@nexura/ui": "workspace:*",
    "@tanstack/react-query": "5.101.0",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-router-dom": "7.17.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
